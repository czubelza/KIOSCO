<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<AnchorPane fx:id="rootPane" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ProductosController">
   <children>
      <BorderPane>
         <center>
            <AnchorPane prefHeight="2000" prefWidth="2000">   <!-- Grande para que se expanda -->
            
               <children>
            
                  <!-- Barra superior -->
                  <VBox alignment="CENTER_LEFT" layoutX="20.0" layoutY="20.0" prefWidth="900.0">
                     <children>
                        <Label text="Gestión de Productos">
                           <font>
                              <Font name="System Bold" size="26.0" />
                           </font>
                        </Label>
                        
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                           <children>
                              <TextField fx:id="txtBuscar" prefWidth="300.0" promptText="Buscar por nombre o código..." />
                              <Button fx:id="btnBuscar" text="🔎 Buscar" />
                              <ComboBox fx:id="cbFiltro" prefWidth="180.0" promptText="Todas las categorías" />
                              <Button fx:id="btnNuevo" style="-fx-font-weight: bold; -fx-base: #4CAF50;" text="➕ Nuevo Producto" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
            
                  <!-- Tabla - Se expande -->
                  <TableView fx:id="tableProductos" layoutX="20.0" layoutY="100.0" prefHeight="450.0" prefWidth="880.0">
                     <columns>
                        <TableColumn fx:id="colCodigo" prefWidth="80.0" text="Código" />
                        <TableColumn fx:id="colNombre" prefWidth="200.0" text="Nombre" />
                        <TableColumn fx:id="colCategoria" prefWidth="120.0" text="Categoría" />
                        <TableColumn fx:id="colPrecioVenta" prefWidth="100.0" text="P. Venta" />
                        <TableColumn fx:id="colStock" prefWidth="80.0" text="Stock" />
                        <TableColumn fx:id="colStockMin" prefWidth="80.0" text="Stock Min" />
                        <TableColumn fx:id="colProveedor" prefWidth="140.0" text="Proveedor" />
                     </columns>
                  </TableView>
            
                  <!-- Botones inferiores -->
                  <HBox layoutX="20.0" layoutY="570.0" spacing="15.0">
                     <children>
                        <Button fx:id="btnModificar" text="✏️ Modificar" />
                        <Button fx:id="btnEliminar" text="🗑 Eliminar" />
                        <Button fx:id="btnRefrescar" text="🔄 Actualizar" />
                     </children>
                  </HBox>
            
               </children>
            </AnchorPane>
         </center>
      </BorderPane>
   </children>
</AnchorPane>
